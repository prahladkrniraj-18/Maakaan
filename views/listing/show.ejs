<% layout("/layouts/boilerplate")-%>
<body>
  <div class="row">
    <div class="col-8 offset-2 mt-3 mb-3">
      <h2>Listing Details:</h2>
    </div>
    <div class="card col-6 offset-2">
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-image"
        alt="listing_image"
      />
      <div class="card-body">
        <p class="card-text"><b><%= listing.title %></b></p>
        <p><%= listing.description %></p>
        <p>&#8377;<%= listing.price.toLocaleString("en-IN") %></p>
        <p><%= listing.location %></p>
        <p><%= listing.country %></p>
        <div class="button">
          <form action="/listing/<%=listing._id %>/edit" method="get">
            <button class="btn btn-red btn-outline-danger">Edit</button>
          </form>
          <form
            action="/listing/<%=listing._id %>?_method=DELETE"
            method="post"
          >
            <button class="btn btn-dark">Delete</button>
          </form>
        </div>
      </div>
      <br />
      <!-- <a href="/listing"><button>Back to Listings</button></a> -->
    </div>
  </div>
</body>
